# Big regenerable artifacts — local-only, NOT in version control (2026-05-11).
# DBs rebuild via scripts/init_db.py + fetchers; RAG index via `python -m library.rag build`;
# ITR zips re-download from CVM. Were the cause of a 118 GB Git LFS bloat → moved off-repo.
data/*.db
library/chunks_index.db
library/ri/cache/ITR/*.zip

# Podcast MP3 cache — descarregado, transcrito, e apagado por pod_poll.
# Mantém só o transcript em DB; binários não pertencem ao repo.
data/podcast_audio/

# Smoke test logs (manual debug, regeneráveis)
logs/smoke_*.log
