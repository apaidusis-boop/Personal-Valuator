    <script>
    // $('.module-breadcrumb a.module-breadcrumb_home-link').text("Investors");
    //ADDING NOINDEX TAG FOR THEIR OWN COVEO SEARCH SCRIPT
    $("header").prepend("<!-- BEGIN NOINDEX -->").append("<!-- END NOINDEX -->");
