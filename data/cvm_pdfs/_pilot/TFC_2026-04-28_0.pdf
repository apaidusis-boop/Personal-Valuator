		var mainYoffset = mainRow.offset().top - $(window).scrollTop() - navBarHeight;
		if(navBarHeight - $(window).scrollTop() <= 0) {
			navBar.addClass('fixed-top');
		} else {
			navBar.removeClass('fixed-top');
		}
		if(mainYoffset <= 0) {
			navBar.addClass('in-view');
		} else {
			navBar.removeClass('in-view');
		}
	}
	$(window).scroll(function() {
		scroll();
	});
	scroll();
});
</script>



<script>
	//Adds banner to distinguish between past events and future events

	$(document).ready(function() {
		var currentPath = window.location.href;
		var currentPathArr = currentPath.split('/');
		var lastPosition = currentPathArr.length;
		var currentPage = currentPathArr[lastPosition - 1];


		if (currentPage == "events-and-presentation") {
            if ($('.wd_events_past_summary').length > 0) {// if this exists, there are upcoming and past events
                $("<div class="+ "wd_event_indicator" + ">Upcoming Events</div>").insertBefore('.wd_events_list');
                $("<div class="+ "wd_event_indicator" + ">Past Events</div>").insertBefore('.wd_events_past_summary');	
            } else {
                $("<div class="+ "wd_event_indicator" + ">Past Events</div>").insertBefore('.wd_events_list');	
            }
		}
	

		$('.wd_events_tab_future').click(function() {

			$('.wd_event_indicator').remove();
			$('.wd_past_events').remove();
			$("<div class="+ "wd_future_events" + ">Upcoming Events</div>").insertBefore('.wd_events_list');
		});
		$('.wd_events_tab_past').click(function() {
			$('.wd_event_indicator').remove();
			$('.wd_future_events').remove();
			$("<div class="+ "wd_past_events" + ">Past Events</div>").insertBefore('.wd_events_list');
			

		});
	});
</script>

<script>
	$(document).ready(function(){
		//Category Nav
		$('.wd_dropdown').click(function(){
			$(this).toggleClass('wd_open');
		});

	});
</script>

<script>
	/*************************
	Corporate and Social Responsibilty 
	*************************/

	//Prepends the item name to the the top of each item
	$('.wd_pageid_58 .wd_category_items .item').each(function() {
		$(this).prepend($(this).find('.item_name'));
	})

	//Wraps each item with it's respective link
	$('.wd_pageid_58 .wd_category_items .item').each(function() {
		var categoryLink = $(this).find('.item_name a').attr(
			'href');
		$(this).find('.wd_imagetable img').wrap('<a href='+categoryLink+' data-wa-track-clk="1" data-wa-linktype="download"></a>')
	});

	//Creates a seperate container for the first item in the list 
	$('.wd_pageid_58 .wd_category_items_16 .item:first').wrap('<div class="responsibilty_reports"></div>');
	$('.wd_pageid_58 .wd_category_items_16 .item:first').addClass('responsibilty_report');
	/*************************
	Annual Reports & Proxy Statements 
	*************************/

	//Prepends the item name to the the top of each item
	// $('.wd_pageid_20 .wd_category_items .item').each(function() {
	// 	$(this).prepend($(this).find('.item_name'));
	// })

	//Wraps each item with it's respective link
	$('.wd_pageid_20 .wd_category_items .item').each(function() {
		var imageLink = $(this).find('.wd_imagetable a').attr('href');
		// var categoryLink = $(this).find('.item_name a').attr(
		// 	'href');
		$(this).wrapInner('<a href='+imageLink+' data-wa-track-clk="1" data-wa-linktype="download"></a>');
		$(this).find('wd_imagetable img').unwrap();
	});

	//WCAG Attachment Icons
	$('.wd_attachment_icon img').each(function(){
		$(this).attr('alt','');
	});

	//SEC Filings
	$('.wd_pageid_127 .wd_filer_label').insertAfter('.wd_selectors');

	// WCAG

	$('.wd_newsfeed_releases-detail .wd_asset_gallery a.wd_link_underlay').attr('aria-label', 'Open Modal');
	$('.wd_pageid_43.wd_item_page iframe').each(function (i) {
		let id = $(this).attr('id');
		$(this).attr('id', `${id}-${i}`);
	});

	$('.wd_newsfeed_releases-detail .wd_asset_inline').each(function () {
		if ( $('.wd_icon_overlay a span.fa-search-plus', this)[0] ) {
			console.log("true");
			$('.wd_icon_overlay > .wd_link_underlay', this).remove();
		}
	});

	setTimeout(function(){
		$('.wd_pageid_65 .wd_category_items').each(function(){
			$(this).removeAttr('role');
			$('.item_name', this).removeAttr('role');
		});

		$('.wd_pageid_65 .wd_category .item_name').each(function(){	
			$(this).removeAttr('aria-selected');
			$(this).attr('role', 'button');
		});
	}, 500);

	$('.wd_pageid_20 .wd_category_items .item > a a').each(function(){
		// remove nested <a>
		$(this).contents().unwrap();
	});


</script>

