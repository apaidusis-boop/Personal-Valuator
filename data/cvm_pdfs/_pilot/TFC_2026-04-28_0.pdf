<script type="text/javascript" wd_script_id="view_printable_script" nonce="MThhOGViODJkNzBiN2RlZmI2MmVhNzdkMTVjMzY0OWMyYTc2M2EyNg==">
	function view_printable() {
		var loc = window.location;
		var sep = (loc.search == "") ? "?" : "&";
		var url = loc.protocol+"//"+loc.host+loc.pathname+loc.search+sep+"printable"+loc.hash;
		window.open(url, "_blank", "");
	}
</script>
