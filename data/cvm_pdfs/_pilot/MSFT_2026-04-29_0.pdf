<p class="MsoListParagraphCxSpMiddle" style="margin-top:6.0pt;margin-right:0in;
margin-bottom:6.0pt;margin-left:.5in;text-indent:-.25in;line-height:14.0pt"><span lang="EN-US" style="font-size:10.0pt;font-family:Symbol;color:#666666">·<span style="font:7.0pt &quot;Times New Roman&quot;">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
