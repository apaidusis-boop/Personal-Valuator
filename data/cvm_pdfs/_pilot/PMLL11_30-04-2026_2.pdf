"ImageObject","url":"https:\/\/files.fiis.com.br\/uploads\/pexels-tom-zhou-228473-14785236-1-scaled.webp","width":"1200","height":"800"},"about":[{"@context":"https:\/\/schema.org\/","@type":"DefinedTerm","termCode":"bom dia","inDefinedTermSet":{"@type":"DefinedTermSet","name":"post_tag","url":"https:\/\/fiis.com.br\/tag\/bom-dia\/"},"mainEntityOfPage":{"@type":"WebPage","@id":"https:\/\/fiis.com.br\/tag\/bom-dia\/"}},{"@context":"https:\/\/schema.org\/","@type":"DefinedTerm","termCode":"Bom dia fiis","inDefinedTermSet":{"@type":"DefinedTermSet","name":"post_tag","url":"https:\/\/fiis.com.br\/tag\/bom-dia-fiis\/"},"mainEntityOfPage":{"@type":"WebPage","@id":"https:\/\/fiis.com.br\/tag\/bom-dia-fiis\/"}},{"@context":"https:\/\/schema.org\/","@type":"DefinedTerm","termCode":"Fundos Imobili\u00e1rios","inDefinedTermSet":{"@type":"DefinedTermSet","name":"post_tag","url":"https:\/\/fiis.com.br\/tag\/fundos-imobiliarios\/"},"mainEntityOfPage":{"@type":"WebPage","@id":"https:\/\/fiis.com.br\/tag\/fundos-imobiliarios\/"}},{"@context":"https:\/\/schema.org\/","@type":"DefinedTerm","termCode":"Fundos Imobili\u00e1rios (FIIs)","inDefinedTermSet":{"@type":"DefinedTermSet","name":"post_tag","url":"https:\/\/fiis.com.br\/tag\/fundos-imobiliarios-fiis\/"},"mainEntityOfPage":{"@type":"WebPage","@id":"https:\/\/fiis.com.br\/tag\/fundos-imobiliarios-fiis\/"}},{"@context":"https:\/\/schema.org\/","@type":"DefinedTerm","termCode":"IFIX","inDefinedTermSet":{"@type":"DefinedTermSet","name":"post_tag","url":"https:\/\/fiis.com.br\/tag\/ifix\/"},"mainEntityOfPage":{"@type":"WebPage","@id":"https:\/\/fiis.com.br\/tag\/ifix\/"}}]}</script>
