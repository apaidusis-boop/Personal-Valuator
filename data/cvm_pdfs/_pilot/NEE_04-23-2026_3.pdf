      <!-- For Skip to Main Content Only --> 
      <h2>
        NextEra Energy first-quarter 2026 financial results available on company's website
      </h2>
      <p>
        04/23/2026
      </p>
      <div class="pr-body float100">
        <style>
          hl1{
            display:none;
          }
          hl2, hl3{
            display:block;
            font-weight: normal;
            line-height: 1.8rem;
            margin-bottom: 5px;
