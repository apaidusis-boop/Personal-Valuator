    <script>
    window.addEventListener("load", function () {
        if (GetViewType() == "0") return;
        setTimeout(handleConsentStatus, 250);
    });
    
    function handleConsentStatus() {
        if (OnetrustActiveGroups && OnetrustActiveGroups.includes("C0002")) {
            window.Q4Tracker.startTracking();
        } else {
            // Clear tracking cookies when consent is withdrawn
            var cookies = document.cookie.split(";");
            for (var i = 0; i < cookies.length; i++) {
                var cookie = cookies[i].split("=")[0].trim();
                if (cookie.includes("__uxq412__")) {
                    document.cookie = cookie + "=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
                }
            }
        }
    }
</script>
