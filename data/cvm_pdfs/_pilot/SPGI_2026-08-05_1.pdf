<script>
    var irwHorizontalNav = {
        navSource: '.irw-nav-source',
        navDestination: '.ir-horizontal-nav',
        selectedClass: ' current current-sub-menu current-item',
        expandedClass: ' current-item ',
        openedClass: 'current',
        navigationData: [],
        recursiveTemplate: (
            /* beautify preserve:start */
            // @formatter:off
            '<ul role="menu" class="{{selectedClass}} irMenu irw-sub-menu irw-page-key-329004">' +
                '{{#children}}' +
                    '<li class="{{selectedClass}} sirw-sub-menu-item core-menu-list-item  score-component score-megamenu-basic-item  {{#hasChildren}}has-sub{{/hasChildren}}">' +
                        '<a target="{{target}}" class="{{#hasChildren}}abc{{/hasChildren}}" href="{{href}}">{{{text}}}</a>{{#hasChildren}} <i class="fa fa-caret-down"></i>{{/hasChildren}}' +
                        '{{#hasChildren}}{{>recurse}}{{/hasChildren}}' +
                    '</li>' +
                '{{/children}}' +
            '</ul>'
            // @formatter:on
            /* beautify preserve:end */
        ),
        navigationTemplate: (
            /* beautify preserve:start */
            // @formatter:off
            '{{#.}}' +
                '<ul class="irw-menu score-menu-list score-component irw-Cuurent-page-key-1073751494" id="irw-menu-toggle-wrapper">' +
                    '{{#children}}' +
                        '<li style="z-index: 1;" class="{{expandedClass}} {{selectedClass}} {{^hasChildren}}irw-menu-item has-no-child score-menu-list-item  score-component score-megamenu-basic-item{{/hasChildren}}{{#hasChildren}}irw-menu-item irw-menu-item-has-child score-menu-list-item  score-component score-megamenu-basic-item {{/hasChildren}}">' +
                            '<a target="{{target}}" href="{{#hasChildren}}javascript:void(0){{/hasChildren}} {{^hasChildren}}{{href}}{{/hasChildren}}">{{{text}}}{{#hasChildren}} <i class="fa fa-plus pull-right" style="padding-top: 3px;"></i>{{/hasChildren}}</a>' +
                            '{{#hasChildren}}{{>recurse}}{{/hasChildren}}' +
                        '</li>' +
                    '{{/children}}' +
                '</ul>' +
            '{{/.}}'
            // @formatter:on
            /* beautify preserve:end */
        ),
        extractChildren: function ($children) {
            var inst = this,
                children = [];
            $children.each(function (i, child) {
                var $this = $(this),
                    $link = $this.find('> a'),
                    $subChild = $this.find('> ul > li'),
                    url = $link.attr('href');

                var urlSplit = url.toLowerCase().split('.'),
                    expanded = $this.hasClass('expanded'),
                    selected = $this.hasClass('selected');

                children.push({
                    expanded: expanded,
                    selected: selected,
                    expandedClass: expanded ? inst.expandedClass : '',
                    selectedClass: selected ? inst.selectedClass : '',
                    href: $link.attr('href'),
                    text: $link.text(),
                    target: urlSplit[urlSplit.length - 1].indexOf('aspx') > -1 ? '_self' : '_blank',
                    children: $subChild.length ? inst.extractChildren($subChild) : null,
                    hasChildren: $subChild.length ? true : false,
                });
            });

            return children;
        },
        render: function () {
            var inst = this;
            $(inst.navDestination).html(function () {
                return Mustache.render(inst.navigationTemplate, inst.navigationData, {"recurse": inst.recursiveTemplate});
            });
        },
        complete: function () {

            // Add current class to to parent <ul> of selected sub page
            $('.current-sub-menu').parent('ul').addClass('current');
            
            // Use minus on loaded page
            $('.current-item').find('i.fa').removeClass('fa-plus').addClass('fa-minus');

            // Opening the main left hand menu on click           
            if ($(window).width() < 769) {
                $(".investor-side-bar").appendTo("#irw-append-sec");
            }
            $('.spgi-investor-menu #irw-menu-toggle-wrapper > li.irw-menu-item-has-child > a').click(function () {

                var checkElement = $(this).next();

                if ((checkElement.is('ul.irw-sub-menu')) && (checkElement.is(':visible'))) {
                    checkElement.slideUp('normal').prev('a').find('i.fa').removeClass('fa-minus').addClass('fa-plus');;
                }

                if ((checkElement.is('ul.irw-sub-menu')) && (!checkElement.is(':visible'))) {

                    $('.spgi-investor-menu #irw-menu-toggle-wrapper > li.irw-menu-item-has-child ul.irw-sub-menu:visible').slideUp('normal').prev('a').find('i').removeClass('fa-minus').addClass('fa-plus');;
                    checkElement.slideDown('normal').prev('a').find('i.fa').removeClass('fa-plus').addClass('fa-minus');
                }

                if (checkElement.is('ul.irw-sub-menu ')) {
                    return false;
                } else {
                    return true;
                }
            });

            $('#irw-mobile-nav #irw-menu-toggle-wrapper > li.irw-menu-item-has-child > a').click(function () {

                var checkElement = $(this).next();

                if ((checkElement.is('ul.irw-sub-menu')) && (checkElement.is(':visible'))) {
                    checkElement.slideUp('normal').prev('a').find('i.fa').removeClass('fa-minus').addClass('fa-plus');;
                }

                if ((checkElement.is('ul.irw-sub-menu')) && (!checkElement.is(':visible'))) {

                    $('#irw-mobile-nav #irw-menu-toggle-wrapper > li.irw-menu-item-has-child ul.irw-sub-menu:visible').slideUp('normal').prev('a').find('i').removeClass('fa-minus').addClass('fa-plus');;
                    checkElement.slideDown('normal').prev('a').find('i.fa').removeClass('fa-plus').addClass('fa-minus');
                }

                if (checkElement.is('ul.irw-sub-menu ')) {
                    return false;
                } else {
                    return true;
                }
            });

            $('#irw-menu-toggler').click(function () {
                $('#irw-menu-toggle-wrapper').toggle();
            });
    
        },
        init: function () {
            var inst = this;

            $(inst.navSource).find('> ul').each(function (i, list) {
                var $this = $(this),
                    $children = $this.find('> li');

                inst.navigationData = inst.extractChildren($children);
            });

            inst.render();
            inst.complete();
        }
    }

    irwHorizontalNav.init();
</script>

