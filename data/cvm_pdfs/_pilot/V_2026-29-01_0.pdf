<script type="text/javascript">
  $(document).ready(function(){
     
      $ModuleYearNavContainer = $('.yearDD .ModuleYearNavContainer').not('.custom');
      var newHTMLList = '<ul class="dropdown-menu" role="menu">';
      var newHTMLButton = '<div class="btn-group">';
        newHTMLButton += '<button type="button" class="btn btn-default dropdown-toggle" data-toggle="dropdown">';

      $ModuleYearNavContainer.children('a.ModuleYearLink').each(function() {
        $this = $(this);
        
        thisHref = $this.attr('href');
        thisID = ( $this.attr('id') ? ' id="'+ $this.attr('id') +'"' : '' );
        thisClass = ( $this.attr('class') ? ' class="'+ $this.attr('class') +'"' : '' );
        thisYear = $this.text();
        console.log(thisYear);

        if( thisClass.indexOf('selected') != -1 ) {
          newHTMLButton += '<span class="icon-arrow-down"></span>' + thisYear;
          thisClass += ' selected';
        }
        newHTMLList += '<li><a href="'+ thisHref +'"'+ thisID +thisClass +'">'+ thisYear +'</a></li>';

      });

      newHTMLList += '</ul>';
      newHTMLButton += '</button>';
      newHTMLButton += newHTMLList;
      $ModuleYearNavContainer.html(newHTMLButton).show();
  });
</script>
