    <script type="text/javascript">
$(function() {
    // Initialize Fancybox
    $("a.fancybox").fancybox();

    // Footer navigation title fix
    $(".FooterNavigation").prepend('<h1>Visa Inc.</h1>');

    // Mobile Footer Menu
    $('.FooterLinks h1').on('click', function() {
        if( $(window).width() > 640 ) return;
        $this = $(this);
        $menu = $this.siblings('ul');
        $menu.stop(true, true).slideToggle(200);
    });

    // Fill in home page Grid Menu
    var $GridMenu = $('.GridMenu > .level1');
    var createDDMenu = function( boxClass, index ) {
        var MenuListHtml = $GridMenu.children('li').eq( index ).children('ul.level2');
        $('.'+ boxClass ).find('.dropdown-menu').html( ( MenuListHtml ? MenuListHtml.html() : '<li>Nothing Found</li>' ) );
    }
    createDDMenu( 'box-fanancial-information', 2);
    createDDMenu( 'box-corporate-governance', 3);
    createDDMenu( 'box-investor-resources', 7);

    // Home Featured Boxes
    var homeLayout = $('.LayoutHomePage');
    var $box1 = homeLayout.find('.FeaturedEventLatest');
    var $box2 = homeLayout.find('.FeaturedEvent3');     
    var $box3 = homeLayout.find('.EventAnnual');

    $box1.on('click', function(e) {
        e.preventDefault();
        var box1Link = $box1.find('.ModuleHeadlineLink').attr('href');
        window.location.href = box1Link;
    });

    $box2.on('click', function(e) {
        e.preventDefault();
        var box2Link = $box2.find('.ModuleHeadlineLink').attr('href');
        window.location.href = box2Link;
    });
    
    $box3.on('click', function(e) {
        e.preventDefault();
        var box3Link = $box3.find('.ModuleHeadlineLink').attr('href');
        window.location.href = box3Link;
    });

    // $('.btn-group').click(function() {
    //    $(this).toggleClass('open');
    // });

    $('.btn-group').on('click', 'button', function() {
       $(this).parent().toggleClass('open');
    });
});
</script>
</div></span><span class='Q4FooterDiv10'><div id="_ctrl0_ctl33_divModuleContainer" class="ModuleContent hidden">
