            <script>

    window.addEventListener('load', function() {
        if (GetViewType() == '0') return;
        var consentValues = document.cookie.replace(/(?:(?:^|.*;\s*)wscrCookieConsent\s*\=\s*([^;]*).*$)|^.*$/, "$1");

        // Only fire SP tracking if both consent values are true
        if (consentValues.includes("1=true") && consentValues.includes("3=true")) {
            window.Q4Tracker.startTracking();
        } else {
            var cookies = document.cookie.split(";");
            for (var i = 0; i < cookies.length; i++) {
                if (cookies[i].includes("uxq412__")) {
                    var cookie = cookies[i].split("=");
                    document.cookie = cookie[0] + "=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
                }
            }
        }
    });
</script>

