rtalignb bwpadl0 bwpadr0 bwalignr bwrowaltcolor0 bwwidth1" colspan="1" rowspan="1"><p class="bwcellpmargin bwalignl">&nbsp;</p></td><td class="bwvertalignb bwleftsingle bwpadl0 bwpadr0 bwalignr bwrowaltcolor0 bwwidth1" colspan="1" rowspan="1"><p class="bwalignr bwcellpmargin">&nbsp;</p></td><td class="bwvertalignb bwpadl0 bwpadr0 bwalignr bwrowaltcolor0 bwwidth8" colspan="1" rowspan="1"><p class="bwalignr bwcellpmargin">0.02</p></td><td class="bwvertalignb bwpadl0 bwpadr0 bwalignr bwrowaltcolor0 bwwidth1" colspan="1" rowspan="1"><p class="bwcellpmargin bwalignl">&nbsp;</p></td><td class="bwvertalignb bwleftsingle bwpadl0 bwrowaltcolor0" colspan="2" rowspan="1"><p class="bwcellpmargin">&nbsp;</p></td><td class="bwvertalignb bwleftsingle bwpadl0 bwrowaltcolor0 bwwidth1" colspan="1" rowspan="1"><p class="bwcellpmargin">&nbsp;</p></td><td class="bwvertalignb bwleftsingle bwpadl0 bwpadr0 bwalignr bwrowaltcolor0 bwwidth1" colspan="1" rowspan="1"><p class="bwalignr bwcellpmargin">&nbsp;</p></td><td class="bwvertalignb bwpadl0 bwpadr0 bwalignr bwrowaltcolor0 bwwidth8" colspan="1" rowspan="1"><p class="bwalignr bwcellpmargin">0.05</p></td><td class="bwtablemarginb bwblockalignl bwrowaltcolor0 bwwidth1" colspan="1" rowspan="1"></td><td class="bwvertalignb bwleftsingle bwpadl0 bwpadr0 bwalignr bwrowaltcolor0 bwwidth1" colspan="1" rowspan="1"><p class="bwalignr bwcellpmargin">&nbsp;</p></td><td class="bwvertalignb bwpadl0 bwpadr0 bwalignr bwrowaltcolor0 bwwidth8" colspan="1" rowspan="1"><p class="bwalignr bwcellpmargin">(1.07</p></td><td class="bwvertalignb bwpadl0 bwpadr0 bwalignr bwrowaltcolor0 bwwidth1" colspan="1" rowspan="1"><p class="bwcellpmargin bwalignl">)</p></td><td class="bwvertalignb bwleftsingle bwrightsingle bwpadl0 bwrowaltcolor0" colspan="2" rowspan="1"><p class="bwcellpmargin">&nbsp;</p></td></tr><tr><td class="bwvertalignb bwleftsingle bwpadl1 bwwidth41" colspan="1" rowspan="1"><p class="bwcellpmargin">Asset impairment, exit and implementation costs</p></td><