8273); --darkreader-inline-border-bottom: var(--darkreader-border-000000, #8c8273);" data-darkreader-inline-border-top="" data-darkreader-inline-border-bottom="">$</td><td style="border-top: 1pt solid black; border-bottom: 3pt double black; padding-left: 0px; padding-right: 0px; text-align: right; vertical-align: bottom; --darkreader-inline-border-top: var(--darkreader-border-000000, #8c8273); --darkreader-inline-border-bottom: var(--darkreader-border-000000, #8c8273);" data-darkreader-inline-border-top="" data-darkreader-inline-border-bottom="">(6,844</td><td style="border-top: 1pt solid black; border-bottom: 3pt double black; padding-left: 0px; text-align: left; vertical-align: bottom; --darkreader-inline-border-top: var(--darkreader-border-000000, #8c8273); --darkreader-inline-border-bottom: var(--darkreader-border-000000, #8c8273);" data-darkreader-inline-border-top="" data-darkreader-inline-border-bottom="">)</td></tr></tbody></table> <p>&nbsp;</p>  <p align="justify">Management defines free cash flow as net cash provided by operating activities, less net cash used in investing activities, adjusted for acquisitions and divestitures. For the six months ended March 31, 2026, net cash provided by operating activities was $661 million; net cash used in investing activities was $501 million; there were no adjustments for acquisitions or divestitures; and free cash flow was $160 million. For the six months ended March 31, 2025, net cash provided by operating activities was $474 million; net cash used in investing activities was $425 million; there were no adjustments for acquisitions or divestitures; and free cash flow was $49 million. The Company is unable to provide a reconciliation of any projected free cash flow measure to its comparable GAAP financial measure without unreasonable efforts. This is due to an inability to calculate the comparable GAAP projected metrics, including operating income and total production costs, given the unknown effect, timing, and potential significance of certain income statement items.</p> <table align="center" style="border-collapse: collapse; width:99%; border-collapse:collapse ;"><tbody><tr><td style="max-width:30%; width:30%; min-width:30%;;vertical-align: bottom ; ">&nbsp;</td><td style="max-width:70%; width:70%; min-width:70%;;vertical-align: bottom ; ">&nbsp;</td></tr><tr><td style="vertical-align: bottom ; ">Natalie M. Fischer<br>Investor Relations <br>716-857-7315</td><td style="vertical-align: bottom ; ">Timothy J. Silverstein<br>Chief Financial Officer <br>716-857-6987</td></tr></tbody></table> <p>&nbsp;</p> <img alt="" class="__GNW8366DE3E__IMG" src="https://www.globenewswire.com/newsroom/ti?nf=OTcwOTkwOSM3NTczMjUxIzIwMDY5OTk="> <br><img alt="" src="https://ml.globenewswire.com/media/NjU5YWQwMDgtMTYyNC00YzkxLTk0ZDYtZWFmNjI3ODIwN2NlLTEwMTg1NzItMjAyNi0wNC0yOS1lbg==/tiny/National-Fuel-Gas-Company.png" referrerpolicy="no-referrer-when-downgrade"><p><a href="https://www.globenewswire.com/NewsRoom/AttachmentNg/07f75cec-aeab-43a4-a9d5-72c04284edfd"><img src="https://ml.globenewswire.com/media/07f75cec-aeab-43a4-a9d5-72c04284edfd/small/nf-corporate-v-rgb-png.png" border="0" width="150" height="77" alt="Primary Logo"></a></p>
Source: National Fuel Gas Company</div>
