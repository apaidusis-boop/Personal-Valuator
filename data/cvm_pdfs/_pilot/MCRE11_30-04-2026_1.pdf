	<figure class="article__cover">
		<picture>
			<source media="(max-width: 760px)" srcset="https://files.fiis.com.br/uploads/pexels-daniel-dan-47825192-7542862-Copia-395x246.webp">
			<img data-od-xpath="/HTML/BODY/DIV[@class=&#039;wrapper newsContent&#039;]/*[1][self::ARTICLE]/*[3][self::FIGURE]/*[1][self::PICTURE]/*[2][self::IMG]" src="https://files.fiis.com.br/uploads/pexels-daniel-dan-47825192-7542862-Copia-1200x747.webp" alt="Mais de 170 fundos imobiliários (FIIs) divulgam dividendos (30); veja valores" />
