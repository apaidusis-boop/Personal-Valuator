      <h3 class="module-details_title">
        <span id="_ctrl0_ctl79_lblModuleDetailHeadline">Aflac Incorporated Announces First Quarter 2026 Results</span>
      </h3>
      <div class="module_container module_container--content">
        <div class="module_date-time">
          <span id="_ctrl0_ctl79_lblDate" class="module_date-text">04/29/2026</span>
        </div>
