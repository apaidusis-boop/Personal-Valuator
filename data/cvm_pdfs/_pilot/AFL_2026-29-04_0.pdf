        <div class="module_container module_container--inner">
            <script>
    $("a[href*='#cookie-settings']").attr('href', 'javascript:return false');
    
   $('document').ready(function () {   
    $('.toggleCookieSettings').click(function (e) {
        e.preventDefault();
