                <span id="_ctrl0_ctl70_lblWebsiteRecording" class="module-q4-credits_powered-text">Powered By Q4 Inc.</span>
                <span id="_ctrl0_ctl70_lblVersion" class="module-q4-credits_version-text">5.179.1.3</span>
                <span class="sr-only">(opens in new window)</span>
