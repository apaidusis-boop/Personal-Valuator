</div></span><span class='Q4FooterDiv25'><div id="_ctrl0_ctl76_divModuleContainer" class="module module-embed hidden">
    <div class="module_container module_container--outer">
        
        <div class="module_container module_container--inner">
            <script>
    function handleConsentStatus() {
        if (OnetrustActiveGroups && OnetrustActiveGroups.includes("C0002")) {
            window.Q4Tracker.startTracking();
        } else {
            // Clear tracking cookies when consent is withdrawn
            var cookies = document.cookie.split(";");
            for (var i = 0; i < cookies.length; i++) {
                var cookie = cookies[i].split("=")[0].trim();
                if (cookie.includes("__uxq412__")) {
                    document.cookie = cookie + "=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
                }
            }
        }
    }

    window.addEventListener("load", function () {
        if (GetViewType() == "0") return;
        setTimeout(handleConsentStatus, 250);
    });
</script>
        </div>
    </div>
</div></span><span class='Q4FooterDiv2'><div id="_ctrl0_ctl82_divModuleContainer" class="module module-embed hidden">
    <div class="module_container module_container--outer">
        
        <div class="module_container module_container--inner">
            <script type="text/javascript">
q4App.scollingTable('.module-details .module_body table');
</script>
