    <script>
        (function () {
            const iframe = document.getElementById("q4l-idp-iframe");
            iframe.onload = function () {
                const redirectUrl = iframe.contentWindow.location.href;
                if (redirectUrl !== iframe.src) {
                    iframe.src = redirectUrl;
                }
            }
        })();
    </script>
    

