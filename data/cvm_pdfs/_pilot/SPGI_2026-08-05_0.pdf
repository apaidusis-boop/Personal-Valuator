    <script>
    window.addEventListener("load", function () {
        if (GetViewType() == "0") return;
        setTimeout(handleConsentStatus, 250);
    });
    
    function handleConsentStatus() {
        if (OnetrustActiveGroups && OnetrustActiveGroups.includes("C0002")) {
            window.Q4Tracker.startTracking();
        } else {
            // Clear tracking cookies when consent is withdrawn
            var cookies = document.cookie.split(";");
            for (var i = 0; i < cookies.length; i++) {
                var cookie = cookies[i].split("=")[0].trim();
                if (cookie.includes("__uxq412__")) {
                    document.cookie = cookie + "=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
                }
            }
        }
    }
</script>
</div></span><span class='Q4FooterDiv2'><div id="_ctrl0_ctl44_divModuleContainer" class="module module-embed">
    
    <script type="text/javascript">
    q4App.scrollingTable('.module-details .module_body table');

    //Redirecting the RSS feed link to the Q4 location
    $(".xn-content a:contains('RSS')").attr('href', '/contact-investor-relations/rss-feeds');
    
    var newsTags = [];
    newsTags = $(".module-news-details").attr("data-tag").split(" ");
	$('.irw-investor-presentation-title').after('<div class="irw-news-tags"></div>');
    $.each(newsTags, function(i, item) {
        if (i != 0) {
            item = ", " + item;
        }
        $('.irw-news-tags').append(item.replace(/-/g, ' '));
    });
</script>
