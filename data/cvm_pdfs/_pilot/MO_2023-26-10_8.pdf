            <h2 class="module-details_title">
                <span id="_ctrl0_ctl39_lblModuleDetailHeadline">Altria Reports 2023 Third-Quarter and Nine-Months Results; Narrows 2023 Full-Year Earnings Guidance</span>
            </h2>
            <div class="module_container module_container--content">
                <div class="module_date-time">
                    <span id="_ctrl0_ctl39_lblDate" class="module_date-text">10/26/2023</span>
                </div>
