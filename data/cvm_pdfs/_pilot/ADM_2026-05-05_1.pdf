                        <h3 id="_ctrl0_ctl63_lblModuleDetailTitle" class="evergreen-item-detail-title evergreen-news-title">
                            <span id="_ctrl0_ctl63_spanNewsDetailsTitle" style="font-weight:bold;">ADM Reports First Quarter 2026 Results</span>
                        </h3>
                    </div>
