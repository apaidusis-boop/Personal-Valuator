        <div class="module_container module_container--inner">
            <h2 class="module-details_title h3">
                <span id="_ctrl0_ctl58_lblModuleDetailHeadline">Nucor Invites You to Join Its First Quarter of 2026 Conference Call on the Web</span>
            </h2>
            <div class="module_container module_container--content">
                <div class="module_date-time">
                    <span id="_ctrl0_ctl58_lblDate" class="module_date-text">04/14/2026</span>
                </div>
                <div class="module_links q4icons">
                    <div class="module_related-document">
                        <a href="//s202.q4cdn.com/531038915/files/doc_news/Nucor-Invites-You-to-Join-Its-First-Quarter-of-2026-Conference-Call-on-the-Web-2026.pdf" id="_ctrl0_ctl58_hrefDownload" class="module_link module_news-details_download" target="_blank"><span class="q4icons_icon" aria-hidden="true"></span><span id="_ctrl0_ctl58_lblDownload" class="module_link-text">Download</span><span class="sr-only">(opens in new window)</span><span id="_ctrl0_ctl58_lblDocument" class="module_file-size">PDF 149 KB</span></a>
