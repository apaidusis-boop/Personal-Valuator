    <script type="text/javascript">
        function onLoad__ctrl0_ctl33_recaptcha() {
            grecaptcha.render('_ctrl0_ctl33_btnSubmit', {
                'sitekey': '6LcKf8wZAAAAADYEeFvKUvdj80FVct5G98mSJ29W',
                'callback': 'onSubmit__ctrl0_ctl33_recaptcha',
                'size': 'invisible'
            });
            // Prevent immediate postback: ASP.NET adds onclick (Page_ClientValidate + __doPostBack) to the button.
            // Only the reCAPTCHA callback should trigger postback, after the challenge is completed.
            var btn = document.getElementById('_ctrl0_ctl33_btnSubmit');
            if (btn) btn.removeAttribute('onclick');
        }

        function onSubmit__ctrl0_ctl33_recaptcha(token) {
            var captchaTokenField = document.getElementById('_ctrl0_ctl33_recaptcha_hdnCaptchaToken');

            captchaTokenField.value = token;
            __doPostBack('_ctrl0$ctl33$btnSubmit', "");
        }
    </script>

