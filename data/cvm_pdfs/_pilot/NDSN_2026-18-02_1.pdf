                    <div id="_ctrl0_ctl55_divViewAllNews" class="evergreen-news-view-all-wrapper evergreen-news-view-all-left">
                        <a href="https://investors.nordson.com/news/default.aspx" id="_ctrl0_ctl55_hrefViewAllNews" class="evergreen-news-view-all-link evergreen-button">View All News</a>
